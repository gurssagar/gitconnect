{
  "name": "gitconnect",
  "version": "1.0.0",
  "description": "Multi-GitHub Account Manager - Auto & Explicit Mode",
  "main": "dist/index.js",
  "bin": {
    "gitconnect": "./dist/cli.js",
    "gc": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build"
  },
  "keywords": [
    "git",
    "github",
    "cli",
    "account-manager",
    "ssh",
    "multi-account",
    "developer-tools"
  ],
  "author": "GitConnect",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "inquirer": "^9.2.12",
    "nanoid": "^5.1.6",
    "node-ssh": "^13.1.0",
    "ora": "^7.0.1",
    "simple-git": "^3.20.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
